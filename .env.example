# ForensicsAI Platform - Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# REQUIRED ENVIRONMENT VARIABLES
# ============================================

# JWT Authentication (Minimum 32 characters each)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-here

# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/forensics_platform?retryWrites=true&w=majority

# ============================================
# SERVER CONFIGURATION
# ============================================

PORT=3000
NODE_ENV=development
API_VERSION=v1
BASE_URL=http://localhost:3000

# ============================================
# SECURITY CONFIGURATION
# ============================================

# CORS - Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# FILE UPLOADS
# ============================================

UPLOAD_MAX_SIZE=104857600
UPLOAD_DEST=./uploads
EVIDENCE_PATH=./uploads/evidence
REPORTS_PATH=./uploads/reports
SANDBOX_LOGS_PATH=./uploads/sandbox-logs

# ============================================
# BLOCKCHAIN CONFIGURATION
# ============================================

BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_NETWORK=sepolia
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/your-project-id
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_CHAIN_ID=11155111
BLOCKCHAIN_EXPLORER_URL=https://sepolia.etherscan.io

# Verification Settings
AUTO_VERIFY_ON_UPLOAD=false
STORE_HASHES_ON_CHAIN=false
VERIFICATION_BATCH_SIZE=10

# ============================================
# AI SERVICE CONFIGURATION
# ============================================

AI_SERVICE_ENABLED=false
AI_SERVICE_URL=http://localhost:8000

# ============================================
# SANDBOX AGENT CONFIGURATION
# ============================================

SANDBOX_RUNTIME_URL=http://127.0.0.1:8765
SANDBOX_AGENT_SECRET=your-shared-sandbox-agent-secret
# Optional: pin Python interpreter used to launch the sandbox agent from the backend.
# PYTHON_PATH=
# Optional: override the project root used when launching the sandbox agent.
# SANDBOX_PROJECT_ROOT=

# ============================================
# LOGGING CONFIGURATION
# ============================================

LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=30

# ============================================
# SMTP CONFIGURATION (for OTP emails)
# ============================================

# Use either SMTP_HOST or SMTP_SERVICE.
# `SMTP_TO` is optional. If set, OTP emails are delivered to that mailbox instead
# of the address entered in the registration form.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_REJECT_UNAUTHORIZED=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# SMTP_PASSWORD can be used instead of SMTP_PASS
SMTP_FROM=ForensicsAI <your-email@gmail.com>
# Optional fixed recipient for testing/shared mailboxes
SMTP_TO=
