# Forensics Platform - Environment Configuration
# Copy this file to .env and fill in the values

# =================== SERVER CONFIG ===================
PORT=3000
NODE_ENV=development
API_VERSION=v1
BASE_URL=http://localhost:3000

# =================== MONGODB CONFIG ===================
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/forensics_platform?retryWrites=true&w=majority
MONGODB_DATABASE=forensics_platform
MONGODB_OPTIONS=maxPoolSize=10&wtimeout=30000

# =================== JWT CONFIG ===================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRY=30d

# =================== SECURITY ===================
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =================== FILE UPLOAD ===================
UPLOAD_MAX_SIZE=104857600
UPLOAD_DEST=./uploads
ALLOWED_FILE_TYPES=.json,.zip,.pdf,.log,.txt,.png,.jpg,.jpeg

# =================== EVIDENCE STORAGE ===================
EVIDENCE_PATH=./uploads/evidence
REPORTS_PATH=./uploads/reports
SANDBOX_LOGS_PATH=./uploads/sandbox-logs

# =================== AI SERVICE (Future) ===================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_ENABLED=false

# =================== LOGGING ===================
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=30

# =================== SANDBOX SYNC (Future) ===================
SANDBOX_SYNC_ENABLED=true
SANDBOX_API_KEY=

# =================== BLOCKCHAIN VERIFICATION ===================
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_NETWORK=sepolia
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/your-project-id
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_CHAIN_ID=11155111
BLOCKCHAIN_EXPLORER_URL=https://sepolia.etherscan.io
AUTO_VERIFY_ON_UPLOAD=false
STORE_HASHES_ON_CHAIN=false