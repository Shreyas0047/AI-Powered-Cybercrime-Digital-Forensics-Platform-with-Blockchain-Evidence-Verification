{
  "services": {
    "backend": {
      "host": "127.0.0.1",
      "port": 3000,
      "url": "http://localhost:3000",
      "apiPrefix": "/api/v1",
      "healthEndpoint": "/api/v1/operations/health"
    },
    "frontend": {
      "host": "127.0.0.1",
      "port": 5173,
      "url": "http://localhost:5173"
    },
    "aiService": {
      "host": "127.0.0.1",
      "port": 8000,
      "url": "http://localhost:8000",
      "healthEndpoint": "/health"
    },
    "sandboxAgent": {
      "host": "127.0.0.1",
      "port": 8765,
      "url": "http://127.0.0.1:8765",
      "healthEndpoint": "/health",
      "wsEndpoints": {
        "telemetry": "ws://127.0.0.1:8765/telemetry/live",
        "logs": "ws://127.0.0.1:8765/logs/live"
      }
    }
  },
  "startupOrder": ["backend", "aiService", "sandboxAgent", "frontend"],
  "healthCheckTimeout": 5000,
  "healthCheckRetries": 10,
  "healthCheckInterval": 2000
}
