  "type": "object",
  "required": [
    "simulator_id",
    "display_name",
    "version",
    "entry_point",
    "safety_profile"
  ],
  "properties": {
    "simulator_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "entry_point": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "safety_profile": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
